# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_GUILD_ID=your_discord_guild_id

# Overseerr (Seerr)
# Preferred: full URL (supports reverse proxy paths), e.g. https://apexflix.xyz/coreylad/overseerr
OVERSEERR_URL=http://localhost:5055
# Legacy fallback key (optional)
OVERSEERR_BASE_URL=
OVERSEERR_API_KEY=your_overseerr_api_key
OVERSEERR_DEFAULT_USER_ID=1
OVERSEERR_ALLOW_INSECURE_TLS=false

# Jellyfin
# Preferred: full URL (supports reverse proxy paths), e.g. https://apexflix.xyz/coreylad/jellyfin
JELLYFIN_URL=http://localhost:8096
# Legacy fallback key (optional)
JELLYFIN_BASE_URL=
JELLYFIN_API_KEY=your_jellyfin_api_key
JELLYFIN_USER_ID=
JELLYFIN_USERNAME=
JELLYFIN_CLIENT_NAME=ApexFlix
JELLYFIN_DEVICE_NAME=ApexFlix Bot
JELLYFIN_DEVICE_ID=apexflix-bot
JELLYFIN_CLIENT_VERSION=1.0.0
JELLYFIN_ALLOW_INSECURE_TLS=false
JELLYFIN_LOG_DIR=/var/log/jellyfin

# App
PORT=1337
REQUEST_STATUS_POLL_SECONDS=60
LOG_LEVEL=info
TRUST_PROXY=true
APP_BASE_PATH=/
